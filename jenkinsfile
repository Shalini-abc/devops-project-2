pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/YOUR_USERNAME/devops-project.git'
            }
        }

        stage('Terraform Apply') {
            steps {
                dir('terraform') {
                    sh 'terraform init'
                    sh 'terraform apply -auto-approve'
                }
            }
        }

        stage('Update Inventory') {
            steps {
                script {
                    def ip = sh(
                      script: "terraform -chdir=terraform output -raw public_ip",
                      returnStdout: true
                    ).trim()

                    sh """
                    sed -i 's/<EC2_PUBLIC_IP>/${ip}/g' ansible/inventory.ini
                    """
                }
            }
        }

        stage('Ansible Deploy') {
            steps {
                dir('ansible') {
                    sh 'ansible-playbook -i inventory.ini playbook.yml'
                }
            }
        }
    }
}
